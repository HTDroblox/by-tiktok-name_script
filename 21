-- ===== HÀM KIỂM TRA MỤC TIÊU (Giữ nguyên thuật toán xịn của ông) =====
local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    local root = char.HumanoidRootPart
    local bestTarget = nil
    local shortestDistance = math.huge
    local viewportCenter = Camera.ViewportSize / 2

    for _, model in ipairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model ~= char then
            local hum = model:FindFirstChildOfClass("Humanoid")
            local targetPart = model:FindFirstChild(CONFIG.AimPart)
            
            if hum and hum.Health > 0 and targetPart then
                if CONFIG.TargetTeam then
                    local player = Players:GetPlayerFromCharacter(model)
                    if player and player.Team == LocalPlayer.Team then continue end
                end

                local distToTarget = (root.Position - targetPart.Position).Magnitude
                if distToTarget <= CONFIG.MaxDistance then
                    if CONFIG.IgnoreWalls then
                        local rayParams = RaycastParams.new()
                        rayParams.FilterType = Enum.RaycastFilterType.Exclude
                        rayParams.FilterDescendantsInstances = {char, model}
                        local rayResult = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * distToTarget, rayParams)
                        if rayResult then continue end 
                    end

                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                        if screenDist < shortestDistance then
                            shortestDistance = screenDist
                            bestTarget = model
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

local function isTargetValid(model)
    if not model or not model.Parent then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local part = model:FindFirstChild(CONFIG.AimPart)
    if not hum or hum.Health <= 0 or not part then return false end

    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local root = char.HumanoidRootPart

    local dist = (root.Position - part.Position).Magnitude
    if dist > CONFIG.MaxDistance then return false end

    if CONFIG.IgnoreWalls then
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {char, model}
        local rayResult = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * dist, rayParams)
        if rayResult then return false end
    end

    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end

    return true
end

local function updateUI()
    if AimlockEnabled then
        if CurrentTarget then
            UIStroke.Color = CrosshairColor
            LockIcon.ImageColor3 = CrosshairColor
        else
            UIStroke.Color = Color3.fromRGB(255, 255, 50)
            LockIcon.ImageColor3 = Color3.fromRGB(255, 255, 50)
        end
    else
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
        LockIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)
        TargetGui.Parent = nil
    end
end

-- ===== LUỒNG 1: KHÓA CAMERA (Hình ảnh - RenderStep) =====
RunService:BindToRenderStep("HTDCamLock", Enum.RenderPriority.Camera.Value + 100, function()
    if not AimlockEnabled then return end

    local needNewTarget = false
    if not CurrentTarget or not isTargetValid(CurrentTarget) then
        needNewTarget = true
    end

    if needNewTarget then
        CurrentTarget = getBestTarget()
        updateUI()
    end

    if CurrentTarget then
        local targetPart = CurrentTarget:FindFirstChild(CONFIG.AimPart)
        if targetPart then
            if TargetGui.Parent ~= targetPart then
                TargetGui.Parent = targetPart
            end
            -- Ép Camera bằng CFrame.new (Tốc độ cao nhất, không bị filter)
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
        else
            CurrentTarget = nil
            updateUI()
        end
    else
        TargetGui.Parent = nil
    end
end)

-- ===== LUỒNG 2: KHÓA NHÂN VẬT (Vật lý - Heartbeat) =====
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")

    if not char or not hum or not root then return end

    if AimlockEnabled and CurrentTarget and CurrentTarget:FindFirstChild(CONFIG.AimPart) then
        hum.AutoRotate = false
        local targetPart = CurrentTarget:FindFirstChild(CONFIG.AimPart)
        
        -- Dùng lookVector để xoay thay vì đè vị trí gốc (Hết bị lỏng/giật khi dash)
        local direction = (targetPart.Position - root.Position).Unit
        local lookPos = root.Position + Vector3.new(direction.X, 0, direction.Z)
        root.CFrame = CFrame.new(root.Position, lookPos)
    else
        hum.AutoRotate = true
    end
end)

-- ===== CHỨC NĂNG BẬT/TẮT =====
local function toggleAimlock()
    AimlockEnabled = not AimlockEnabled
    if not AimlockEnabled then
        CurrentTarget = nil
        local char = LocalPlayer.Character
        if char and char:FindFirstChildOfClass("Humanoid") then
            char:FindFirstChildOfClass("Humanoid").AutoRotate = true
        end
        TargetGui.Parent = nil
    end
    updateUI()
end

ToggleButton.MouseButton1Click:Connect(toggleAimlock)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == CONFIG.LockKey then
        toggleAimlock()
    end
end)
