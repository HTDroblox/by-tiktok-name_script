-- Hàm tiện ích dùng chung
local function SafeTeleport(pos)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = pos
    end
end

local function BuyItem(name, price, currency)
    print("[Shop] Mua " .. name .. " giá " .. price .. " " .. currency)
    Fluent:Notify({ Title = "Shop", Content = "Đã mua " .. name .. "!", Duration = 3 })
end

local function GoToSea(n)
    local pos = { [2]=Vector3.new(1000,0,2000), [3]=Vector3.new(-500,0,-500) }
    if pos[n] then SafeTeleport(CFrame.new(pos[n])) end
end

local function RunLoop(name, time, msg)
    local coro = nil
    Options[name]:OnChanged(function()
        if Options[name].Value then
            if coro then coroutine.close(coro); coro = nil end
            coro = coroutine.create(function()
                while Options[name].Value do
                    print(msg)
                    task.wait(time or 3)
                end
            end)
            coroutine.resume(coro)
        else
            if coro then coroutine.close(coro); coro = nil end
        end
    end)
end

-- Tạo logo hình tròn
local function CreateLogo()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Name = "HTD"

    local ToggleButton = Instance.new("ImageButton")
    ToggleButton.Parent = ScreenGui
    ToggleButton.BackgroundColor3 = Color3.fromRGB(35,35,35)
    ToggleButton.BackgroundTransparency = 0.1
    ToggleButton.BorderColor3 = Color3.fromRGB(255,0,0)
    ToggleButton.BorderSizePixel = 2
    ToggleButton.Position = UDim2.new(0.01,0,0.85,0)
    ToggleButton.Size = UDim2.new(0,55,0,55)
    ToggleButton.Image = "rbxassetid://125357138591690"
    ToggleButton.ImageRectSize = Vector2.new(0,0)
    ToggleButton.Name = "ToggleButton"

    local Border = Instance.new("UICorner")
    Border.Parent = ToggleButton
    Border.CornerRadius = UDim.new(1,0)

    local Shadow = Instance.new("UIStroke")
    Shadow.Parent = ToggleButton
    Shadow.Color = Color3.fromRGB(255,50,50)
    Shadow.Thickness = 2
    Shadow.Transparency = 0.5
    Shadow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    ToggleButton.MouseEnter:Connect(function()
        ToggleButton.BackgroundTransparency = 0
        Shadow.Transparency = 0
    end)
    ToggleButton.MouseLeave:Connect(function()
        ToggleButton.BackgroundTransparency = 0.1
        Shadow.Transparency = 0.5
    end)

    local dragging = false
    local dragStart, startPos
    ToggleButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = ToggleButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    ToggleButton.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                              startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    ToggleButton.MouseButton1Click:Connect(function()
        Window:Toggle()
        ToggleButton.BackgroundColor3 = Color3.fromRGB(255,50,50)
        task.wait(0.1)
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35,35,35)
    end)

    local Glow = Instance.new("ImageLabel")
    Glow.Parent = ToggleButton
    Glow.BackgroundTransparency = 1
    Glow.Position = UDim2.new(-0.2,0,-0.2,0)
    Glow.Size = UDim2.new(1.4,0,1.4,0)
    Glow.Image = "rbxassetid://2763166771"
    Glow.ImageColor3 = Color3.fromRGB(255,0,0)
    Glow.ImageTransparency = 0.8
    Glow.ZIndex = 0
    Glow.Name = "Glow"

    task.spawn(function()
        while ScreenGui.Parent do
            Glow.ImageTransparency = 0.6 + math.sin(tick()*1.5)*0.3
            task.wait(0.05)
        end
    end)

    Fluent:Notify({ Title = "HTD.roblox", Content = "Bấm logo để mở/tắt menu!", Duration = 3 })
end
CreateLogo()

