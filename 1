    S:AddParagraph({ Title = "CÀI ĐẶT", Content = "" })
    S:AddToggle({ Title = "ESP 100", Default = false })
    S:AddDropdown({ Title = "Thời gian", Values = {"1 - Ngày","2 - Đêm"}, Default = "1 - Ngày" })
    S:AddDropdown({ Title = "Tốc độ bay", Values = {"150","200","250","300","325","350","400","450","500"}, Default = "250" })
    S:AddToggle({ Title = "Miss", Default = false })
    S:AddToggle({ Title = "Xóa xương mù (Fog)", Default = false })
    S:AddButton({
        Title = "Xóa xương mù ngay",
        Callback = function()
            game.Lighting.FogEnd = 1000; game.Lighting.FogStart = 0
            for _, v in pairs(workspace:GetChildren()) do
                if v.Name:lower():find("bone") or v.Name:lower():find("skeleton") then v:Destroy() end
            end
            Fluent:Notify({ Title = "Settings", Content = "Đã xóa xương mù!", Duration = 3 })
        end
    })
    S:AddToggle({ Title = "Shader Model", Default = false })
    S:AddToggle({ Title = "Fast Attack", Default = false })
    S:AddToggle({ Title = "Super Attack", Default = false })
    S:AddToggle({ Title = "Super Fast Attack", Default = false })
    S:AddToggle({ Title = "HTD Attack", Default = false })
    S:AddToggle({ Title = "Full Light", Default = false })

    -- Xử lý Settings
    Options.ClearFog:OnChanged(function()
        if Options.ClearFog.Value then
            game.Lighting.FogEnd = 1000; game.Lighting.FogStart = 0
        else
            game.Lighting.FogEnd = 100000; game.Lighting.FogStart = 0
        end
    end)

    Options.FlySpeed:OnChanged(function()
        local speed = tonumber(Options.FlySpeed.Value)
        if speed then
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = speed end
        end
    end)

    Options.ESP100:OnChanged(function() print("[ESP] ESP100:", Options.ESP100.Value) end)
    Options.FullLight:OnChanged(function()
        if Options.FullLight.Value then
            game.Lighting.Brightness = 10; game.Lighting.ClockTime = 12
        else
            game.Lighting.Brightness = 1; game.Lighting.ClockTime = 12
        end
    end)
    Options.TimeMode:OnChanged(function()
        game.Lighting.ClockTime = (Options.TimeMode.Value == "1 - Ngày") and 12 or 0
    end)
    Options.MissMode:OnChanged(function() print("[Settings] Miss:", Options.MissMode.Value) end)
end
