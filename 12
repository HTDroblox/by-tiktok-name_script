-- Lưu camera gốc
local originalCameraType = Camera.CameraType

-- Tìm mục tiêu (không FOV giới hạn để cứng)
local function getClosestTarget()
    local closest = nil
    local minDist = math.huge
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char and obj:FindFirstChild(AimPart) then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and not obj:IsA("Accessory") and Players:GetPlayerFromCharacter(obj) ~= LocalPlayer then
                local dist = (char.HumanoidRootPart.Position - obj[AimPart].Position).Magnitude
                if dist < MaxDistance then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(obj[AimPart].Position)
                    if onScreen then
                        local d = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if d < minDist then
                            minDist = d
                            closest = obj
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- Vô hiệu hóa script camera của game (nếu có) để tránh xung đột
pcall(function()
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("LocalScript") and obj.Name:lower():find("camera") then
            obj.Disabled = true
        end
    end
end)

-- ===== AIMLOCK CỨNG + CROSSHAIR SCALE =====
RunService:BindToRenderStep("HiruzHardLock", Enum.RenderPriority.Camera.Value + 1, function()
    if AimlockEnabled and CurrentTarget and CurrentTarget:FindFirstChild(AimPart) then
        -- Khóa camera scriptable
        if Camera.CameraType ~= Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Scriptable
        end

        local targetPos = CurrentTarget[AimPart].Position
        local character = LocalPlayer.Character
        if character then
            local head = character:FindFirstChild("Head")
            local basePos = head and head.Position or (character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0)) or Camera.CFrame.Position
            local camPos = basePos + CameraOffset

            -- Gán CFrame mới mỗi frame
            Camera.CFrame = CFrame.new(camPos, targetPos)

            -- Tính khoảng cách và scale
            local dist = (camPos - targetPos).Magnitude
            local rawScale = ScaleFactor / dist
            local scale = math.clamp(rawScale, MinScale, MaxScale)

            -- Cập nhật crosshair
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
            if onScreen then
                CrossContainer.Visible = true
                CrossContainer.Position = UDim2.new(0, screenPos.X, 0, screenPos.Y)
                updateCrosshair(scale)
            else
                CrossContainer.Visible = false
            end
        end
    else
        CrossContainer.Visible = false
        if Camera.CameraType ~= originalCameraType then
            Camera.CameraType = originalCameraType
        end
    end
end)

-- Bấm nút
ToggleButton.MouseButton1Click:Connect(function()
    AimlockEnabled = not AimlockEnabled
    if AimlockEnabled then
        CurrentTarget = getClosestTarget()
        if not CurrentTarget then
            AimlockEnabled = false
            CrossContainer.Visible = false
        end
    else
        CurrentTarget = nil
        CrossContainer.Visible = false
        if Camera.CameraType ~= originalCameraType then
            Camera.CameraType = originalCameraType
        end
    end
end)

-- Tự động tìm target mới
game:GetService("RunService").Heartbeat:Connect(function()
    if AimlockEnabled and CurrentTarget then
        local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 or not CurrentTarget.Parent then
            CurrentTarget = getClosestTarget()
            if not CurrentTarget then
                AimlockEnabled = false
                CrossContainer.Visible = false
                if Camera.CameraType ~= originalCameraType then
                    Camera.CameraType = originalCameraType
                end
            end
        end
    end
end)
