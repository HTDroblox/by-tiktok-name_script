local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AimlockEnabled = false
local CurrentTarget = nil
local AimPart = "HumanoidRootPart"
local MaxDistance = 300

-- ===== GÓC NHÌN THỨ 3 =====
local CameraOffset = Vector3.new(0, 1.8, 4) -- cao + lùi sau

-- ===== CROSSHAIR HÌNH V (SCALE ĐỘNG) =====
local CrosshairColor = Color3.fromRGB(255, 255, 255)
local LineThickness = 2.5
local BaseLineLength = 35      -- chiều dài mỗi đường khi scale=1
local BaseDotSize = 8
local MinScale = 0.3
local MaxScale = 3.5
local ScaleFactor = 120        -- hệ số tỉ lệ (càng lớn càng to khi gần)
-- ===========================================

-- Tạo GUI
local ScreenGui = Instance.new("ScreenGui", (gethui and gethui()) or LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "HiruzAimlockV17"
ScreenGui.ResetOnSpawn = false

-- CONTAINER CROSSHAIR
local CrossContainer = Instance.new("Frame", ScreenGui)
CrossContainer.BackgroundTransparency = 1
CrossContainer.Size = UDim2.new(0, 0, 0, 0)
CrossContainer.Position = UDim2.new(0, 0, 0, 0)
CrossContainer.Visible = false

-- Hàm tạo 1 đường thẳng (Frame) với rotation
local function makeLine(parent, length, thick, rot, color)
    local line = Instance.new("Frame", parent)
    line.BackgroundColor3 = color
    line.BackgroundTransparency = 0
    line.Size = UDim2.new(0, length, 0, thick)
    line.Position = UDim2.new(0, -length/2, 0, -thick/2)
    line.Rotation = rot
    return line
end

-- Tạo 4 đường và 1 chấm
local lineTL = makeLine(CrossContainer, BaseLineLength, LineThickness, -45, CrosshairColor)  -- \ trên trái
local lineTR = makeLine(CrossContainer, BaseLineLength, LineThickness, 45, CrosshairColor)   -- / trên phải
local lineBL = makeLine(CrossContainer, BaseLineLength, LineThickness, 45, CrosshairColor)   -- / dưới trái (thực tế là \ nhưng xoay 45)
local lineBR = makeLine(CrossContainer, BaseLineLength, LineThickness, -45, CrosshairColor)  -- \ dưới phải

local dot = Instance.new("Frame", CrossContainer)
dot.BackgroundColor3 = CrosshairColor
dot.BackgroundTransparency = 0
dot.Size = UDim2.new(0, BaseDotSize, 0, BaseDotSize)
dot.Position = UDim2.new(0, -BaseDotSize/2, 0, -BaseDotSize/2)
Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

-- Hàm cập nhật crosshair với scale
local function updateCrosshair(scale)
    local len = BaseLineLength * scale
    local dotSize = BaseDotSize * scale
    local thick = LineThickness * scale

    -- Cập nhật từng line
    for _, line in ipairs({lineTL, lineTR, lineBL, lineBR}) do
        line.Size = UDim2.new(0, len, 0, thick)
        line.Position = UDim2.new(0, -len/2, 0, -thick/2)
    end

    dot.Size = UDim2.new(0, dotSize, 0, dotSize)
    dot.Position = UDim2.new(0, -dotSize/2, 0, -dotSize/2)
end

