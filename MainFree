Options.FlySpeed:OnChanged(function()
    local speed = tonumber(Options.FlySpeed.Value)
    if speed then
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = speed end
    end
end)
Options.ESP100:OnChanged(function()
    if Options.ESP100.Value then print("[ESP] Bật ESP 100") else print("[ESP] Tắt ESP 100") end
end)
Options.FullLight:OnChanged(function()
    if Options.FullLight.Value then game.Lighting.Brightness = 10; game.Lighting.ClockTime = 12
    else game.Lighting.Brightness = 1; game.Lighting.ClockTime = 12 end
end)
Options.TimeMode:OnChanged(function()
    if Options.TimeMode.Value == "1 - Ngày" then game.Lighting.ClockTime = 12
    else game.Lighting.ClockTime = 0 end
end)
-- ============================================================
--  COROUTINE CHO TOGGLE
-- ============================================================
local function runLoop(name, time, msg)
    Options[name]:OnChanged(function()
        local coro
        if Options[name].Value then
            coro = coroutine.create(function()
                while Options[name].Value do print(msg); task.wait(time or 3) end
            end)
            coroutine.resume(coro)
        else
            if coro then coroutine.close(coro); coro = nil end
        end
    end)
end

