-- 4. HỆ THỐNG GLOW BÁO HIỆU
local EspGlow = Instance.new("Highlight")
EspGlow.Name = "HiruzAimGlow"
EspGlow.FillColor = Color3.fromRGB(255, 50, 50)
EspGlow.FillTransparency = 0.6
EspGlow.OutlineColor = Color3.fromRGB(255, 255, 255)
EspGlow.OutlineTransparency = 0
EspGlow.Enabled = false
EspGlow.Parent = workspace

local function applyGlow(target)
    EspGlow.Adornee = target
    EspGlow.Enabled = true
end

local function removeGlow()
    EspGlow.Enabled = false
    EspGlow.Adornee = nil
end

-- 5. HÀM TÌM MỤC TIÊU 
local function getClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= myChar and obj:FindFirstChild(AimPart) then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 and not obj:IsA("Accessory") then
                if Players:GetPlayerFromCharacter(obj) == LocalPlayer then continue end
                
                local actualDistance = (myChar.HumanoidRootPart.Position - obj[AimPart].Position).Magnitude
                if actualDistance > MaxDistance then continue end

                local screenPos, onScreen = Camera:WorldToViewportPoint(obj[AimPart].Position)
                if onScreen then
                    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    
                    if distanceToCenter < shortestDistance then
                        shortestDistance = distanceToCenter
                        closestTarget = obj
                    end
                end
            end
        end
    end
    return closestTarget
end

-- 6. LÕI AIMLOCK (PRIORITY 1000 - KHÓA SIÊU CỨNG)
RunService:BindToRenderStep("HiruzHardLock", 1000, function()
    if AimlockEnabled and CurrentTarget and CurrentTarget:FindFirstChild(AimPart) then
        local humanoid = CurrentTarget:FindFirstChildOfClass("Humanoid")
        local myChar = LocalPlayer.Character
        
        if humanoid and humanoid.Health > 0 and myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local targetPos = CurrentTarget[AimPart].Position
            local myHRP = myChar.HumanoidRootPart
            
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            local lookPos = Vector3.new(targetPos.X, myHRP.Position.Y, targetPos.Z)
            myHRP.CFrame = CFrame.lookAt(myHRP.Position, lookPos)
        else
            CurrentTarget = nil
            removeGlow()
            AimlockEnabled = false
            UIStroke.Color = Color3.fromRGB(220, 220, 220)
            LockIcon.ImageColor3 = Color3.fromRGB(220, 220, 220)
        end
    end
end)

-- 7. XỬ LÝ BẤM NÚT KẾT HỢP ICON SHIFT LOCK
ToggleButton.MouseButton1Click:Connect(function()
    AimlockEnabled = not AimlockEnabled
    if AimlockEnabled then
        CurrentTarget = getClosestTarget()
        if CurrentTarget then
            applyGlow(CurrentTarget)
            -- Đổi màu viền và icon sang Đỏ khi khóa mục tiêu
            UIStroke.Color = Color3.fromRGB(255, 50, 50)
            LockIcon.ImageColor3 = Color3.fromRGB(255, 50, 50)
        else
            AimlockEnabled = false
            LockIcon.Visible = false
            ToggleButton.Text = "MISS"
            task.wait(0.5)
            ToggleButton.Text = ""
            LockIcon.Visible = true
        end
    else
        CurrentTarget = nil
        removeGlow()
        -- Trả về màu trắng mờ mặc định
        UIStroke.Color = Color3.fromRGB(220, 220, 220)
        LockIcon.ImageColor3 = Color3.fromRGB(220, 220, 220)
    end
end)
