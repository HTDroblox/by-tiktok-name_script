-- ===== TẠO CROSSHAIR DÍNH LÊN NGƯỜI (BillboardGui) =====
local CrosshairColor = Color3.fromRGB(255, 0, 0) -- Đổi sang màu đỏ cho dễ nhìn
local TargetGui = Instance.new("BillboardGui")
TargetGui.Name = "AimlockCrosshair"
TargetGui.AlwaysOnTop = true
TargetGui.Size = UDim2.new(0, 60, 0, 60) -- Kích thước cố định của tâm ngắm
TargetGui.LightInfluence = 0

local Container = Instance.new("Frame", TargetGui)
Container.Size = UDim2.new(1, 0, 1, 0)
Container.BackgroundTransparency = 1

-- Hàm tạo các nét của tâm ngắm
local function makeLine(length, thick, pos, rot)
    local line = Instance.new("Frame", Container)
    line.BackgroundColor3 = CrosshairColor
    line.BorderSizePixel = 0
    line.Size = UDim2.new(0, length, 0, thick)
    line.Position = pos
    line.AnchorPoint = Vector2.new(0.5, 0.5)
    line.Rotation = rot
end

makeLine(20, 2, UDim2.new(0.2, 0, 0.2, 0), -45) -- Trên trái
makeLine(20, 2, UDim2.new(0.8, 0, 0.2, 0), 45)  -- Trên phải
makeLine(20, 2, UDim2.new(0.2, 0, 0.8, 0), 45)  -- Dưới trái
makeLine(20, 2, UDim2.new(0.8, 0, 0.8, 0), -45) -- Dưới phải

local dot = Instance.new("Frame", Container)
dot.BackgroundColor3 = CrosshairColor
dot.Size = UDim2.new(0, 6, 0, 6)
dot.Position = UDim2.new(0.5, 0, 0.5, 0)
dot.AnchorPoint = Vector2.new(0.5, 0.5)
Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

-- ===== HÀM TÌM MỤC TIÊU =====
local function getClosestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    local rootPos = char.HumanoidRootPart.Position
    local closest, minDist = nil, math.huge
    local viewportCenter = Camera.ViewportSize / 2

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild(AimPart) then
                local hum = targetChar:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not targetChar:FindFirstChildOfClass("ForceField") then
                    local targetPos = targetChar[AimPart].Position
                    local dist = (rootPos - targetPos).Magnitude
                    
                    if dist < MaxDistance then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
                        if onScreen then
                            local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                            if screenDist < minDist then
                                minDist = screenDist
                                closest = targetChar
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- ===== MAIN LOOP (Xử lý Aimlock và Gắn Crosshair) =====
RunService:BindToRenderStep("HiruzAimlock", Enum.RenderPriority.Camera.Value + 1, function()
    if AimlockEnabled and CurrentTarget then
        local targetRoot = CurrentTarget:FindFirstChild(AimPart)
        if targetRoot then
            local targetPos = targetRoot.Position
            local _, onScreen = Camera:WorldToViewportPoint(targetPos)
            
            if onScreen then
                -- 1. Gắn BillboardGui trực tiếp lên người chơi
                if TargetGui.Parent ~= targetRoot then
                    TargetGui.Parent = targetRoot
                end
                
                -- 2. Di chuyển Camera (Aimlock Core)
                local currentCFrame = Camera.CFrame
                local lookAtCFrame = CFrame.new(currentCFrame.Position, targetPos)
                Camera.CFrame = currentCFrame:Lerp(lookAtCFrame, Smoothness)
                return
            end
        end
    end
    -- Nếu mất mục tiêu hoặc tắt Aimlock thì gỡ Crosshair
    TargetGui.Parent = nil
end)

-- ===== SỰ KIỆN NÚT BẤM =====
ToggleButton.MouseButton1Click:Connect(function()
    AimlockEnabled = not AimlockEnabled
    
    if AimlockEnabled then
        CurrentTarget = getClosestTarget()
        if not CurrentTarget then
            AimlockEnabled = false
            UIStroke.Color = Color3.fromRGB(255, 255, 255)
        else
            UIStroke.Color = Color3.fromRGB(0, 255, 0) -- Chuyển viền nút thành xanh lá
        end
    else
        CurrentTarget = nil
        TargetGui.Parent = nil
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end
end)

-- ===== XỬ LÝ KHI MỤC TIÊU CHẾT HOẶC BIẾN MẤT =====
RunService.Heartbeat:Connect(function()
    if AimlockEnabled and CurrentTarget then
        local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 or not CurrentTarget.Parent then
            TargetGui.Parent = nil
            CurrentTarget = getClosestTarget()
            
            if not CurrentTarget then
                AimlockEnabled = false
                UIStroke.Color = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end)
