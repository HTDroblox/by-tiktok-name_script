local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AimlockEnabled = false
local CurrentTarget = nil
local AimPart = "HumanoidRootPart"
local MaxDistance = 300
local CameraOffset = Vector3.new(0, 0.3, 0)

-- ===== CÀI ĐẶT CROSSHAIR =====
local CrosshairSize = 60
local LineThickness = 2
local CenterDotSize = 6
local Color = Color3.fromRGB(255, 255, 255)
-- =============================

-- Tạo GUI
local ScreenGui = Instance.new("ScreenGui", (gethui and gethui()) or LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "Aimlock"
ScreenGui.ResetOnSpawn = false

-- Crosshair container
local CrosshairContainer = Instance.new("Frame", ScreenGui)
CrosshairContainer.BackgroundTransparency = 1
CrosshairContainer.Size = UDim2.new(0, CrosshairSize*2, 0, CrosshairSize*2)
CrosshairContainer.Position = UDim2.new(0.5, -CrosshairSize, 0.5, -CrosshairSize)
CrosshairContainer.Visible = false

local function createLine(parent, x, y, width, height, color)
    local line = Instance.new("Frame", parent)
    line.BackgroundColor3 = color
    line.BackgroundTransparency = 0
    line.Size = UDim2.new(0, width, 0, height)
    line.Position = UDim2.new(0, x, 0, y)
    return line
end

local topLine = createLine(CrosshairContainer, CrosshairSize - LineThickness/2, 0, LineThickness, CrosshairSize - CenterDotSize/2, Color)
local bottomLine = createLine(CrosshairContainer, CrosshairSize - LineThickness/2, CrosshairSize + CenterDotSize/2, LineThickness, CrosshairSize - CenterDotSize/2, Color)
local leftLine = createLine(CrosshairContainer, 0, CrosshairSize - LineThickness/2, CrosshairSize - CenterDotSize/2, LineThickness, Color)
local rightLine = createLine(CrosshairContainer, CrosshairSize + CenterDotSize/2, CrosshairSize - LineThickness/2, CrosshairSize - CenterDotSize/2, LineThickness, Color)

local centerDot = Instance.new("Frame", CrosshairContainer)
centerDot.BackgroundColor3 = Color
centerDot.BackgroundTransparency = 0
centerDot.Size = UDim2.new(0, CenterDotSize, 0, CenterDotSize)
centerDot.Position = UDim2.new(0, CrosshairSize - CenterDotSize/2, 0, CrosshairSize - CenterDotSize/2)
Instance.new("UICorner", centerDot).CornerRadius = UDim.new(1, 0)

