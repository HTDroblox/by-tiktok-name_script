-- Lưu loại camera gốc
local originalCameraType = Camera.CameraType

-- Hàm tìm mục tiêu
local function getClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end

    local FOVRadius = 9999 -- không giới hạn FOV (để cứng hơn)

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= myChar and obj:FindFirstChild(AimPart) then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 and not obj:IsA("Accessory") then
                if Players:GetPlayerFromCharacter(obj) == LocalPlayer then continue end
                local dist = (myChar.HumanoidRootPart.Position - obj[AimPart].Position).Magnitude
                if dist < MaxDistance then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(obj[AimPart].Position)
                    if onScreen then
                        local d2 = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if d2 < FOVRadius and d2 < shortestDistance then 
                            shortestDistance = d2 
                            closestTarget = obj 
                        end
                    end
                end
            end
        end
    end
    return closestTarget
end

-- ===== CHÍNH: AIMLOCK CỨNG NHẤT =====
RunService:BindToRenderStep("HiruzHardLock", Enum.RenderPriority.Camera.Value + 1, function()
    if AimlockEnabled and CurrentTarget and CurrentTarget:FindFirstChild(AimPart) then
        -- Khóa camera ở chế độ scriptable (không bị game can thiệp)
        if Camera.CameraType ~= Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Scriptable
        end

        local targetPos = CurrentTarget[AimPart].Position
        local character = LocalPlayer.Character
        if character then
            -- Lấy vị trí mắt hoặc ngực
            local head = character:FindFirstChild("Head")
            local basePos = head and head.Position or (character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0)) or Camera.CFrame.Position
            local camPos = basePos + CameraOffset

            -- Gán CFrame mới liên tục, không có độ trễ
            Camera.CFrame = CFrame.new(camPos, targetPos)

            -- Cập nhật crosshair
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
            if onScreen then
                CrosshairContainer.Visible = true
                CrosshairContainer.Position = UDim2.new(0, screenPos.X - CrosshairSize, 0, screenPos.Y - CrosshairSize)
            else
                CrosshairContainer.Visible = false
            end
        end
    else
        -- Khi tắt aim, khôi phục camera cũ
        if Camera.CameraType ~= originalCameraType then
            Camera.CameraType = originalCameraType
        end
        CrosshairContainer.Visible = false
    end
end)

-- Bật/tắt
ToggleButton.MouseButton1Click:Connect(function()
    AimlockEnabled = not AimlockEnabled
    if AimlockEnabled then
        CurrentTarget = getClosestTarget()
        if not CurrentTarget then 
            AimlockEnabled = false
            CrosshairContainer.Visible = false
        end
    else
        CurrentTarget = nil
        CrosshairContainer.Visible = false
        -- Khôi phục camera gốc
        if Camera.CameraType ~= originalCameraType then
            Camera.CameraType = originalCameraType
        end
    end
end)

-- Tự động tìm mục tiêu mới nếu target chết hoặc mất
game:GetService("RunService").Heartbeat:Connect(function()
    if AimlockEnabled and CurrentTarget then
        local humanoid = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 or not CurrentTarget.Parent then
            CurrentTarget = getClosestTarget()
            if not CurrentTarget then
                AimlockEnabled = false
                CrosshairContainer.Visible = false
                if Camera.CameraType ~= originalCameraType then
                    Camera.CameraType = originalCameraType
                end
            end
        end
    end
end)
