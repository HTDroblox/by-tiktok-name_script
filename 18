-- ===== CẤU HÌNH (TÙY CHỈNH TẠI ĐÂY) =====
local CONFIG = {
    AimPart = "HumanoidRootPart",   -- "Head" nếu muốn headshot, "HumanoidRootPart" để nhắm ngực
    MaxDistance = 400,              -- Tầm quét mục tiêu tối đa
    LockKey = Enum.KeyCode.LeftControl, -- Phím tắt bật/tắt
    IgnoreWalls = true,             -- true = Bắn xuyên tường / false = Chỉ khóa khi nhìn thấy địch
    TargetTeam = false,             -- true = Bỏ qua đồng đội / false = Khóa tất cả
}

